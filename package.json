  "scripts": {
    "dev": "vite",
    "prebuild": "npm run build --prefix packages/soroban_militia_client",
    "build": "vite build",
    "preview": "vite preview",
    "peerserver": "node scripts/peerserver.cjs",
    "contract:build": ".\\stellar-cli-bin\\stellar.exe contract build --manifest-path contracts/soroban_militia/Cargo.toml",
